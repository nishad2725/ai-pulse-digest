# OpenAI API — get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# SendGrid API — get yours at https://app.sendgrid.com/settings/api_keys
# Required permission: Mail Send (Full Access)
SENDGRID_API_KEY=SG....

# Email addresses — FROM_EMAIL must be a verified sender in SendGrid
FROM_EMAIL=digest@yourdomain.com
TO_EMAIL=you@gmail.com

# Scheduler config — comma-separated hours (24h clock) to send the digest
# Default: 4x daily at 10 AM, 1 PM, 4 PM, 8 PM
SCHEDULE_HOURS=10,13,16,20
SCHEDULE_MINUTE=0
SCHEDULE_TIMEZONE=America/New_York
